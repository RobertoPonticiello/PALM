# Server-side secrets for the `chat` / `screening-questions` / `translate` edge functions.
#
# ⚠️  NEVER put these in the root .env or any VITE_* variable — those are bundled
#     into the browser build and would leak the key publicly.
#
# Local dev:  supabase functions serve --env-file supabase/functions/.env
# Deploy:     supabase secrets set OPENAI_API_KEY=... --project-ref xzqwztzosznnzmkofmzn
#             (or set them in the Lovable / Supabase dashboard → Edge Functions → Secrets)

# Which provider the chat function uses: "openai" or "lovable".
# If unset, defaults to "openai" when OPENAI_API_KEY is present, otherwise "lovable".
AI_PROVIDER=openai

# OpenAI — generate at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Chat model. gpt-4o is a safe default (streaming + system role + low temperature).
OPENAI_MODEL=gpt-4o

# Lovable AI Gateway (used as the fallback provider)
LOVABLE_API_KEY=
